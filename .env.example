# ============================================================
# VisionGuard AI - Environment Configuration
# ============================================================
# Copy this file to .env and customize for your deployment.
# ============================================================

# ==================== GENERAL ====================
VG_ENVIRONMENT=production
VG_LOG_LEVEL=INFO

# ==================== REDIS ====================
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=  # Uncomment if authentication required

# ==================== BACKEND SUPERVISOR ====================
BACKEND_PORT=8000
VG_HOST=0.0.0.0

# ==================== ECS (Event Classification) ====================
ECS_REDIS_HOST=redis
ECS_REDIS_PORT=6379
ECS_LOG_LEVEL=INFO

# Database (SQLite)
VG_DB_PATH=/data/visionguard/events.db
VG_MODEL_VERSION=1.0.0

# Classification thresholds
ECS_WEAPON_THRESHOLD=0.50
ECS_FIRE_THRESHOLD=0.40
ECS_FALL_THRESHOLD=0.45

# Correlation settings
ECS_CORRELATION_WINDOW_MS=400
ECS_HARD_TTL_SECONDS=2.0

# Output toggles
ECS_ENABLE_ALERTS=true
ECS_ENABLE_DATABASE=true
ECS_ENABLE_FRONTEND=true

# Webhook (optional)
# ECS_ALERT_WEBHOOK_URL=https://your-webhook.com/alerts

# ==================== CAMERA CAPTURE ====================
CAMERA_LOG_LEVEL=INFO
CAMERA_DEFAULT_FPS=5
CAMERA_MOTION_THRESHOLD=0.02

# ==================== AI WORKERS ====================
WORKER_LOG_LEVEL=INFO
WORKER_MODEL_TYPE=weapon

# Execution provider: CPUExecutionProvider or CUDAExecutionProvider
ONNX_EXECUTION_PROVIDER=CPUExecutionProvider

# ==================== GPU (OPTIONAL) ====================
# Uncomment for GPU workers
# NVIDIA_VISIBLE_DEVICES=all
# NVIDIA_DRIVER_CAPABILITIES=compute,utility
